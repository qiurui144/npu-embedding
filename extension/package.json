{
  "name": "npu-webhook-extension",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run build -- --watch",
    "build": "BUILD_TARGET=pages vite build && BUILD_TARGET=content vite build && BUILD_TARGET=background vite build && cp src/content/indicator.css dist/content/indicator.css",
    "build:pages": "BUILD_TARGET=pages vite build",
    "build:content": "BUILD_TARGET=content vite build",
    "build:background": "BUILD_TARGET=background vite build"
  },
  "dependencies": {
    "preact": "^10.24"
  },
  "devDependencies": {
    "@preact/preset-vite": "2.8.3",
    "vite": "^5.4"
  }
}
