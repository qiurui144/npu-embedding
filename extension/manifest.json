{
  "manifest_version": 3,
  "name": "Attune 私有 AI 知识伙伴",
  "version": "0.6.0",
  "description": "Private AI Knowledge Companion — Local-first, globally augmented, increasingly attuned to your expertise. 自动捕获 AI 对话 + 浏览状态信号 + 注入个人知识库。",
  "_comment_incognito": "per R04 P1-4: incognito 强制不加载，防御 content script JS 检查被绕过的攻击路径",
  "incognito": "not_allowed",
  "permissions": [
    "storage",
    "sidePanel",
    "activeTab",
    "tabs",
    "contextMenus",
    "webNavigation"
  ],
  "host_permissions": [
    "http://localhost/*",
    "http://127.0.0.1/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "dist/background/worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*"
      ],
      "js": ["dist/content/index.js"],
      "css": ["dist/content/indicator.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["<all_urls>"],
      "exclude_matches": [
        "*://chatgpt.com/*",
        "*://claude.ai/*",
        "*://gemini.google.com/*",
        "*://*/login*",
        "*://*/signin*",
        "*://*1password*/*",
        "*://*lastpass*/*",
        "*://*bitwarden*/*",
        "*://accounts.google.com/*"
      ],
      "_comment": "per R18 P0 #3: 排除 AI 网站避免与 dist/content/index.js (AI 对话捕获) 双注入 race",
      "js": ["dist/content/browse_capture.js"],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "dist/sidepanel/index.html"
  },
  "action": {
    "default_popup": "dist/popup/index.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "options_ui": {
    "page": "dist/options/index.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "assets/icon-16.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  }
}
